{
  "name": "fish-realtime",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "start:dev": "TEXT_INPUT=1 node --env-file-if-exists=.env server.js",
    "smoke": "node --env-file-if-exists=.env scripts/smoke.js",
    "smoke:roulette": "node scripts/roulette-smoke.js",
    "probe:roulette": "node scripts/roulette-probe.js",
    "portraits": "node --env-file-if-exists=.env scripts/gen-portraits.js",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@livekit/agents": "^1.5.2",
    "@livekit/agents-plugin-deepgram": "^1.5.2",
    "@livekit/agents-plugin-fishaudio": "^1.5.2",
    "@msgpack/msgpack": "^3.0.0",
    "livekit-client": "^2.20.1",
    "livekit-server-sdk": "^2.17.0",
    "patch-package": "^8.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "sharp": "^0.35.3"
  }
}
