# Required: DEEPGRAM_API_KEY, LLM_BASE_URL, LLM_API_KEY, LLM_MODEL, FISH_API_KEY.
# Everything else has a working default. Commented lines show that default.
#
# This file is only read when it exists on disk (`--env-file-if-exists`). If
# your platform injects env vars directly (k8s secrets, systemd, ECS task
# definition), skip the file entirely — `npm start` works without it.

# STT — Deepgram Flux (turn-taking + transcription in one websocket)
DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=flux-general-en
# DEEPGRAM_EOT_THRESHOLD=0.7
# DEEPGRAM_EAGER_EOT_THRESHOLD=0.5
# DEEPGRAM_EOT_TIMEOUT_MS=3000

# LLM — any OpenAI-compatible /chat/completions endpoint with stream:true
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# TTS — Fish Audio (voices are configured in personas.js)
FISH_API_KEY=
FISH_MODEL=s2.1-pro
FISH_LATENCY_MODE=balanced
# FISH_DEBUG=1                 # verbose TTS websocket logging

PORT=8787

# Mic gate for the browser-side voice-energy detector, in dBFS.
# VAD_THRESHOLD_DB=-40

# Roulette extras — optional.
# OPENAI_API_KEY=              # enables the achievement judge + `npm run portraits`
# JUDGE_MODEL=gpt-5.2
# LOG_EVENTS_STDOUT=1          # mirror data/*.jsonl events to stdout (see README:
#                              # set this anywhere the instance disk is ephemeral)
# TEXT_INPUT=1                 # DEV ONLY — enables typed turn injection. Never
#                              # set this in production.

# LiveKit mode (/lk) — optional. These creds let the web server mint room
# tokens; the worker (lk-agent.js) is HOSTED ON LIVEKIT CLOUD (`lk agent
# deploy`) with FISH_API_KEY + DEEPGRAM_API_KEY as agent secrets. See README.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# LK_STT_MODEL=flux-general-en
# LK_LLM_MODEL=google/gemma-4-31b-it
# Local agent dev only — spawn the worker here under a non-production name:
# LK_AGENT_LOCAL=1
# LK_AGENT_NAME=fish-lk-dev
