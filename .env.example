# STT — Deepgram Flux (turn-taking + transcription in one websocket)
DEEPGRAM_API_KEY=
# DEEPGRAM_EOT_THRESHOLD=0.7
# DEEPGRAM_EAGER_EOT_THRESHOLD=0.5

# LLM — any OpenAI-compatible /chat/completions endpoint with stream:true
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# TTS — Fish Audio (voices are configured in personas.js)
FISH_API_KEY=
FISH_MODEL=s2.1-pro
FISH_LATENCY_MODE=balanced

PORT=8787

# LiveKit mode (/lk) — optional. When set, server.js spawns lk-agent.js and
# /lk serves the same demo over LiveKit (models via LiveKit Inference: no
# Deepgram/LLM keys needed there; Fish voices come from personas.js).
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# LK_AGENT_DISABLED=1  # serve /lk tokens but don't run the worker here
