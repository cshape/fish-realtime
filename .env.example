# STT — Deepgram Flux (turn-taking + transcription in one websocket)
DEEPGRAM_API_KEY=
# DEEPGRAM_EOT_THRESHOLD=0.7
# DEEPGRAM_EAGER_EOT_THRESHOLD=0.5
# DEEPGRAM_EOT_TIMEOUT_MS=3000

# LLM — any OpenAI-compatible /chat/completions endpoint with stream:true
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# TTS — Fish Audio (voices are configured in personas.js)
FISH_API_KEY=
FISH_MODEL=s2.1-pro
FISH_LATENCY_MODE=balanced

PORT=8787

# LiveKit mode (/lk) — optional. These creds let the web server mint room
# tokens; the worker (lk-agent.js) is HOSTED ON LIVEKIT CLOUD (`lk agent
# deploy`) with FISH_API_KEY + DEEPGRAM_API_KEY as agent secrets. See README.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Local agent dev only — spawn the worker here under a non-production name:
# LK_AGENT_LOCAL=1
# LK_AGENT_NAME=fish-lk-dev
